#!/bin/bash
# ffprobe - Lightweight wrapper using ffmpeg
# Checks for audio streams in video files (fast mode)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FFMPEG_BIN="$SCRIPT_DIR/ffmpeg"

# Get input file (last argument)
INPUT_FILE=""
for arg in "$@"; do
  INPUT_FILE="$arg"
done

if [ -z "$INPUT_FILE" ] || [ ! -f "$INPUT_FILE" ]; then
  echo "Usage: ffprobe [options] <input_file>" >&2
  exit 1
fi

# Fast check: Use ffmpeg to only read header/first few packets
# This is much faster than scanning the entire file
# Note: Must use -loglevel info (not error) to see stream information
if "$FFMPEG_BIN" -hide_banner -loglevel info -t 0.1 -i "$INPUT_FILE" 2>&1 | grep -q "Audio:"; then
  # Has audio - print the stream type
  echo "audio"
  exit 0
else
  # No audio stream
  exit 0
fi
